# Anthropic API Key for Claude AI (Stock categorization)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API Key (Theme classification)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Polygon.io API Key (Cloud-friendly price data — replaces yfinance on Railway)
# Get your FREE key from: https://polygon.io/dashboard/signup
# When set, automatically used instead of yfinance (override with PRICE_PROVIDER=yfinance)
POLYGON_API_KEY=your_polygon_api_key_here
